{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Set unit test env",
			"type": "shell",
			"command": "./shf_dev_dev setup_tests",
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"close": true
			},
		},
		{
			"label": "Begin api process",
			"type": "shell",
			"command": "./gradlew bootRun --debug-jvm",
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"close": true
			},
			"options": {
				"cwd": "${workspaceFolder}/src"
			}
		}


	]
}